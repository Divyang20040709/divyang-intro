# Server Settings
PORT=5000
NODE_ENV=development

# Database Settings
# For Local: mongodb://localhost:27017/portfolio
# For Production: Use your MongoDB Atlas connection string
MONGO_URI=your_mongodb_uri_here

# Client URL (For CORS - primarily for local dev)
CLIENT_URL=http://localhost:5173

# SMTP (Gmail example — use an App Password, not your real password)
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
CONTACT_EMAIL=your_email@gmail.com

